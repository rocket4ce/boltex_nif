# ================================================================
# Production env template for docker-compose.production.yml.
# Copy these into Coolify's "Environment Variables" panel.
#
# Variables prefixed `CFG_` are used ONLY at compose parse time — Coolify
# never passes them into the Neo4j container, which keeps the startup logs
# free of "Unrecognized setting" warnings.
# ================================================================

# ---- Required -------------------------------------------------------
CFG_NEO4J_PASSWORD=change-me-long-random-string

# ---- Advertised host -------------------------------------------------
# Neo4j announces its hostname using `SERVICE_FQDN_NEO4J`, which Coolify
# auto-populates with the FQDN it assigns to this resource. No knob is
# exposed here on purpose: if you need an override (custom CNAME, split
# TCP hostname for Bolt, etc.) edit docker-compose.production.yml and
# replace `${SERVICE_FQDN_NEO4J:-localhost}` with your value.

# ---- Compose / container --------------------------------------------
# or 5.26-enterprise (needs license)
COMPOSE_PROJECT_NAME=boltex
CFG_VERSION=5.26-community

# ---- Exposed ports --------------------------------------------------
# Neo4j Browser (HTTP)
# Bolt (TCP) — drivers
# Prometheus (Enterprise; bound localhost)
CFG_HTTP_PORT=7474
CFG_BOLT_PORT=7687
CFG_METRICS_PORT=2004

# ---- Memory tuning (heap ≈ 50%, pagecache ≈ 25% of container memory)
CFG_PAGECACHE=1G
CFG_HEAP_INITIAL=1G
CFG_HEAP_MAX=2G
CFG_CONTAINER_MEMORY=4G
CFG_CONTAINER_MEMORY_RESERVATION=2G

# ---- Database defaults ----------------------------------------------
CFG_DEFAULT_DB=neo4j
CFG_TX_TIMEOUT=120s
CFG_LOCK_TIMEOUT=60s

# ---- Plugins --------------------------------------------------------
# JSON array of plugins to auto-install. APOC core is always safe on
# Community. `graph-data-science` (full) and `bloom` are Enterprise-only.
CFG_PLUGINS_JSON=["apoc"]

# ---- Query logging --------------------------------------------------
# OFF | INFO | VERBOSE
CFG_QUERY_LOG=INFO
CFG_QUERY_LOG_THRESHOLD=500ms

# ---- Backup sidecar -------------------------------------------------
# Uses APOC `apoc.export.cypher.all` via cypher-shell — works on
# Community. Files land in the `neo4j_backups` volume as gzipped
# cypher-shell scripts. Restore with:
#   gunzip -c neo4j-YYYYmmddTHHMMSSZ.cypher.gz | cypher-shell -u neo4j -p ...
# 24 h
CFG_BACKUP_INTERVAL_SECONDS=86400
CFG_BACKUP_RETENTION_DAYS=14
